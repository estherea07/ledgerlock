generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = env("DATABASE_PROVIDER")
  url      = env("DATABASE_URL")
}

model Business {
  id          String   @id @default(cuid())
  name        String
  ownerId     String   @unique
  ownerEmail  String
  ownerPhone  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff        StaffMember[]
  paymentLinks PaymentLink[]
  transactions Transaction[]
  policies     Policy[]
  vaultTokens  VaultToken[]
  auditLogs    AuditLog[]
}

model StaffMember {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  email        String
  role         String
  riskScore    Int      @default(0)
  flagCount    Int      @default(0)
  isActive     Boolean  @default(true)
  auth0UserId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id])
  paymentLinks PaymentLink[]
  transactions Transaction[]
  auditLogs    AuditLog[]
}

model PaymentLink {
  id           String    @id @default(cuid())
  businessId   String
  staffId      String
  amount       Float
  currency     String    @default("NGN")
  service      String
  reference    String    @unique
  url          String
  status       String    @default("pending")
  expiresAt    DateTime
  paidAt       DateTime?
  depositFound Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business    Business     @relation(fields: [businessId], references: [id])
  staff       StaffMember  @relation(fields: [staffId], references: [id])
  transaction Transaction?
}

model Transaction {
  id            String    @id @default(cuid())
  businessId    String
  staffId       String?
  paymentLinkId String?   @unique
  type          String
  amount        Float
  currency      String    @default("NGN")
  vendor        String?
  description   String
  status        String    @default("pending")
  riskLevel     String    @default("low")
  riskReasons   String    @default("[]")
  cibaRequired  Boolean   @default(false)
  cibaStatus    String?
  cibaRequestId String?
  approvedBy    String?
  blockedBy     String    @default("elf")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  business    Business     @relation(fields: [businessId], references: [id])
  staff       StaffMember? @relation(fields: [staffId], references: [id])
  paymentLink PaymentLink? @relation(fields: [paymentLinkId], references: [id])
}

model Policy {
  id         String   @id @default(cuid())
  businessId String
  name       String
  type       String
  value      String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model VaultToken {
  id          String   @id @default(cuid())
  businessId  String
  provider    String
  displayName String
  scopes      String
  tokenRef    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  businessId  String
  staffId     String?
  action      String
  entity      String
  entityId    String?
  description String
  metadata    String   @default("{}")
  performedBy String   @default("elf")
  auth0LogId  String?
  createdAt   DateTime @default(now())

  business Business     @relation(fields: [businessId], references: [id])
  staff    StaffMember? @relation(fields: [staffId], references: [id])
}
